                                            <TextBox Grid.Column="2"
                                                     Text="{Binding RenameCandidate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Loaded="OnInlineRenameTextBoxLoaded"
                                                     BorderThickness="1"
                                                     Padding="1,0" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="확장자" Width="70" SortMemberPath="Extension" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Extension}" Foreground="{Binding HighlightColor}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="크기" Width="84" Binding="{Binding SizeDisplay}" IsReadOnly="True" />
                            <DataGridTextColumn Header="날짜" Width="150" Binding="{Binding LastModified, StringFormat=yyyy-MM-dd HH:mm:ss}" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="속성" Width="88" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Style="{StaticResource PropertyIconButtonStyle}" ToolTip="메모 편집" Click="OnPropertyMemoIconClick">
                                                <TextBlock Text="📝" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#666666" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                                    <Setter Property="Foreground" Value="#9FCBFF" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HasMemo}" Value="True">
                                                                    <Setter Property="Foreground" Value="#66B3FF" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                            <Button Style="{StaticResource PropertyIconButtonStyle}" ToolTip="핀 고정/해제" Click="OnPropertyPinIconClick">
                                                <TextBlock Text="📌" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#666666" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FFE28A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FFD54A" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                            <Button Style="{StaticResource PropertyIconButtonStyle}" ToolTip="파일 즐겨찾기/해제" Click="OnPropertyFavoriteIconClick">
                                                <TextBlock Text="★" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#666666" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FF8FC0" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FF4FA3" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RightPanelIsTileViewEnabled}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>
                    </DataGrid>
                    <ListBox x:Name="RightPanelTilesList"
                             Grid.Row="0"
                             ItemsSource="{Binding RightPanel.Items}"
                             SelectedItem="{Binding RightPanel.SelectedItem, Mode=TwoWay}"
                             SelectionMode="Extended"
                             PreviewMouseLeftButtonDown="OnPanelItemsPreviewMouseLeftButtonDown"
                             PreviewMouseMove="OnPanelItemsPreviewMouseMove"
                             DragOver="OnPanelItemsDragOver"
                             Drop="OnPanelItemsDrop"
                             AllowDrop="True"
                             PreviewMouseRightButtonUp="OnPanelItemsPreviewMouseRightButtonUp"
                             MouseDoubleClick="OnRightPanelDoubleClick"
                             GotFocus="OnRightPanelFocus"
                             Loaded="OnAdaptiveTileListLoaded"
                             SizeChanged="OnAdaptiveTileListSizeChanged"
                             SelectionChanged="OnRightPanelSelectionChanged">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="열기" Click="OnContextOpenClick" />
                                <Separator />
                                <MenuItem Header="복사(C)" Click="OnWinContextCopyClick" />
                                <MenuItem Header="잘라내기(X)" Click="OnWinContextCutClick" />
                                <MenuItem Header="붙여넣기(V)" Click="OnWinContextPasteClick" />
                                <Separator />
                                <MenuItem Header="삭제" Click="OnContextDeleteClick" />
                                <MenuItem Header="이름 바꾸기" Click="OnContextRenameClick" />
                                <Separator />
                                <MenuItem Header="속성" Click="OnWinContextPropertiesClick" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource TileListStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="ItemTemplate" Value="{StaticResource TileItemTemplate}" />
                                <Setter Property="ItemContainerStyle" Value="{StaticResource TileListItemStyle}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RightPanelIsTileViewEnabled}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RightPanelIsCompactListViewEnabled}" Value="True">
                                        <Setter Property="ItemTemplate" Value="{StaticResource CompactListItemTemplate}" />
                                        <Setter Property="ItemContainerStyle" Value="{StaticResource CompactListItemStyle}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                    </ListBox>
                    <Border Grid.Row="1" Background="#D8D8D8" BorderBrush="#A8A8A8" BorderThickness="1,1,1,0" Padding="2,1">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <ToggleButton Width="24"
                                              Height="22"
                                              Margin="2,0,0,0"
                                              Content="{}{"
                                              ToolTip="일치시작"
                                              IsChecked="{Binding RightPanel.QuickFilterStartsWith, Mode=TwoWay}" />
                                <ToggleButton Width="24"
                                              Height="22"
                                              Margin="2,0,0,0"
                                              Content="{}}"
                                              ToolTip="일치"
                                              IsChecked="{Binding RightPanel.QuickFilterExactMatch, Mode=TwoWay}" />
                                <ToggleButton Width="30"
                                              Height="22"
                                              Margin="2,0,0,0"
                                              Content="Aa"
                                              ToolTip="대소문자 구분"
                                              IsChecked="{Binding RightPanel.QuickFilterCaseSensitive, Mode=TwoWay}" />
                                <ToggleButton Width="24"
                                              Height="22"
                                              Margin="2,0,0,0"
                                              Content="F"
                                              ToolTip="파일 포함"
                                              IsChecked="{Binding RightPanel.QuickFilterIncludeFiles, Mode=TwoWay}" />
                                <ToggleButton Width="24"
                                              Height="22"
                                              Margin="2,0,0,0"
                                              Content="D"
                                              ToolTip="디렉토리 포함"
                                              IsChecked="{Binding RightPanel.QuickFilterIncludeDirectories, Mode=TwoWay}" />
                                <Button Width="24"
                                        Height="22"
                                        Margin="2,0,0,0"
                                        Content="X"
                                        ToolTip="초기화"
                                        Click="OnRightFilterResetClick" />
                            </StackPanel>
                            <Grid Margin="0,0,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#2A2A2A" FontSize="11" Text="파일리스트 내 검색" />
                                <TextBox Grid.Column="1"
                                         MinWidth="60"
                                         VerticalContentAlignment="Center"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding RightPanel.QuickFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="OnRightQuickFilterTextChanged"
                                         ToolTip="파일/디렉토리 이름 필터" />
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="0" Grid.RowSpan="2" Margin="2,2,2,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFourPanelMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFourPanelGridLayout}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GridSplitter Grid.Row="1"
                                  Grid.ColumnSpan="3"
                                  Height="4"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="#B8B8B8"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="False"
                                  MouseDoubleClick="OnFourPanelGridSplitterDoubleClick" />
                    <GridSplitter Grid.Column="1"
                                  Grid.RowSpan="3"
                                  Width="4"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  Background="#B8B8B8"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="False"
                                  MouseDoubleClick="OnFourPanelGridSplitterDoubleClick" />
                    <ContentControl Grid.Row="0" Grid.Column="0" Content="{Binding FourPanels[0]}" ContentTemplate="{StaticResource FourPanelItemTemplate}" />
                    <ContentControl Grid.Row="0" Grid.Column="2" Content="{Binding FourPanels[1]}" ContentTemplate="{StaticResource FourPanelItemTemplate}" />
                    <ContentControl Grid.Row="2" Grid.Column="0" Content="{Binding FourPanels[2]}" ContentTemplate="{StaticResource FourPanelItemTemplate}" />
                    <ContentControl Grid.Row="2" Grid.Column="2" Content="{Binding FourPanels[3]}" ContentTemplate="{StaticResource FourPanelItemTemplate}" />
                </Grid>

                <Grid x:Name="FourPanelsHorizontalLayoutGrid">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFourPanelHorizontalLayout}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GridSplitter Grid.Column="1"
                                  Width="4"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  Background="#B8B8B8"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="False"
                                  MouseDoubleClick="OnFourPanelHorizontalSplitterDoubleClick" />
                    <GridSplitter Grid.Column="3"
                                  Width="4"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  Background="#B8B8B8"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="False"
                                  MouseDoubleClick="OnFourPanelHorizontalSplitterDoubleClick" />
                    <GridSplitter Grid.Column="5"
                                  Width="4"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  Background="#B8B8B8"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="False"
                                  MouseDoubleClick="OnFourPanelHorizontalSplitterDoubleClick" />
                    <ContentControl Grid.Column="0" Content="{Binding FourPanels[0]}" ContentTemplate="{StaticResource FourPanelItemTemplate}" />
                    <ContentControl Grid.Column="2" Content="{Binding FourPanels[1]}" ContentTemplate="{StaticResource FourPanelItemTemplate}" />
                    <ContentControl Grid.Column="4" Content="{Binding FourPanels[2]}" ContentTemplate="{StaticResource FourPanelItemTemplate}" />
                    <ContentControl Grid.Column="6" Content="{Binding FourPanels[3]}" ContentTemplate="{StaticResource FourPanelItemTemplate}" />
                </Grid>
            </Grid>

            <GridSplitter Grid.Row="2"
                          Height="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#B8B8B8"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"
                          Margin="2,0"
                          Visibility="Collapsed" />

            <Grid Grid.Row="2" Background="#D8D8D8" Margin="2,0,2,0" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="0" Background="#0A84D6">
                    <TextBlock Margin="6,2" VerticalAlignment="Center" Foreground="White" Text="{Binding LeftCurrentPath}" />
                </Border>
                <Border Grid.Column="2" Margin="0" Background="#0A84D6">
                    <TextBlock Margin="6,2" VerticalAlignment="Center" Foreground="White" Text="{Binding RightCurrentPath}" />
                </Border>
            </Grid>

            <TabControl x:Name="BottomInfoTabs" Grid.Row="3" Margin="2,2,2,0" Background="#E0E0E0" BorderBrush="#A8A8A8" Visibility="Collapsed">
                <TabItem Header="검색 결과">
                    <ListView x:Name="SearchResultsList"
                              ItemsSource="{Binding SearchResults}"
                              SelectionMode="Extended"
                              MouseDoubleClick="OnSearchResultDoubleClick">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="열기" Click="OnSearchContextOpenClick" />
                                <MenuItem Header="포함 폴더 열기" Click="OnSearchContextOpenFolderClick" />
                                <Separator />
                                <MenuItem Header="복사 (다른 패널로)" Click="OnSearchContextCopyClick" />
                                <MenuItem Header="이동 (다른 패널로)" Click="OnSearchContextMoveClick" />
                                <MenuItem Header="삭제" Click="OnSearchContextDeleteClick" />
                                <Separator />
                                <MenuItem Header="즐겨찾기 추가" Click="OnSearchContextFavoriteClick" />
                                <MenuItem Header="핀 고정/해제" Click="OnSearchContextPinClick" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="이름" Width="260" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="유형" Width="110" DisplayMemberBinding="{Binding TypeDisplay}" />
                                <GridViewColumn Header="크기" Width="120" DisplayMemberBinding="{Binding SizeDisplay}" />
                                <GridViewColumn Header="경로" Width="900" DisplayMemberBinding="{Binding FullPath}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>
                <TabItem Header="빠른 접근">
                    <ListView x:Name="QuickAccessList"
                              ItemsSource="{Binding QuickAccessItems}"
                              MouseDoubleClick="OnQuickAccessDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="이름" Width="320" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="분류" Width="220" DisplayMemberBinding="{Binding Category}" />
                                <GridViewColumn Header="경로" Width="860" DisplayMemberBinding="{Binding Path}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>
                <TabItem Header="최근/고정">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ListView Grid.Column="0" x:Name="RecentFilesList" ItemsSource="{Binding RecentFiles}" MouseDoubleClick="OnRecentFileDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="최근 파일" Width="340" DisplayMemberBinding="{Binding Name}" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <ListView Grid.Column="1" x:Name="FrequentFilesList" ItemsSource="{Binding FrequentFiles}" MouseDoubleClick="OnFrequentFileDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="자주 연 파일" Width="340" DisplayMemberBinding="{Binding Name}" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <ListView Grid.Column="2" x:Name="PinnedFoldersList" ItemsSource="{Binding PinnedFolders}" MouseDoubleClick="OnPinnedFolderDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="고정 폴더" Width="340" DisplayMemberBinding="{Binding Name}" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <ListView Grid.Column="3" x:Name="PinnedFilesList" ItemsSource="{Binding PinnedFiles}" MouseDoubleClick="OnPinnedFileDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="고정 파일" Width="340" DisplayMemberBinding="{Binding Name}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="작업 로그">
                    <ListBox ItemsSource="{Binding WorkLogs}" FontFamily="Consolas" />
                </TabItem>
            </TabControl>

            <Border Grid.Row="4" Background="#DCDCDC" BorderBrush="#A8A8A8" BorderThickness="1,1,1,0" Margin="2,2,2,0" Padding="4,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding ElementName=LeftPanelHostGrid, Path=ActualWidth}" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="{Binding ElementName=RightPanelHostGrid, Path=ActualWidth}" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1" Background="#C8C8C8" />
                    <TextBlock Grid.Column="0" Margin="6,2" VerticalAlignment="Center" Foreground="#1F1F1F" Text="{Binding LeftFolderInfo}" />
                    <TextBlock Grid.Column="2" Margin="6,2" VerticalAlignment="Center" Foreground="#1F1F1F" Text="{Binding RightFolderInfo}" />
                </Grid>
            </Border>

        </Grid>
    </DockPanel>

    <Border x:Name="FavoriteFilesOverlayPanel"
            Width="360"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0,0,0,0"
            Background="#FAFAFA"
            BorderBrush="#969696"
            BorderThickness="1"
            CornerRadius="2"
            Padding="6"
            MaxHeight="420"
            Visibility="Collapsed"
            Panel.ZIndex="2000"
            SnapsToDevicePixels="True">
        <TreeView x:Name="FavoriteFilesFlyoutTree"
                  Background="Transparent"
                  BorderThickness="0"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  PreviewMouseLeftButtonUp="OnFavoriteFilesFlyoutTreeMouseLeftButtonUp"
                  KeyDown="OnFavoriteFilesFlyoutTreeKeyDown">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True" />
                    <Setter Property="Padding" Value="2,1" />
                    <Setter Property="Margin" Value="0,1,0,1" />
                    <Setter Property="FontSize" Value="12" />
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="FavoriteNodeIcon"
                                   Text="📁"
                                   Margin="0,0,6,0"
                                   Foreground="#936A00" />
                        <TextBlock x:Name="FavoriteNodeText"
                                   Text="{Binding Name}"
                                   Foreground="#202020" />
                    </StackPanel>
                    <HierarchicalDataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                            <Setter TargetName="FavoriteNodeIcon" Property="Text" Value="📄" />
                            <Setter TargetName="FavoriteNodeIcon" Property="Foreground" Value="#4F5F6F" />
                            <Setter TargetName="FavoriteNodeText" Property="Foreground" Value="#111111" />
                        </DataTrigger>
                    </HierarchicalDataTemplate.Triggers>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Border>

    <Border x:Name="FavoriteFolderOverlayPanel"
            Width="320"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0,0,0,0"
            Background="#FAFAFA"
            BorderBrush="#969696"
            BorderThickness="1"
            CornerRadius="2"
            Padding="6"
            MaxHeight="460"
            Visibility="Collapsed"
            Panel.ZIndex="1999"
            SnapsToDevicePixels="True">
        <TreeView x:Name="FavoriteFolderFlyoutTree"
                  Background="Transparent"
                  BorderThickness="0"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  PreviewMouseLeftButtonUp="OnFavoriteFlyoutTreeMouseLeftButtonUp"
                  KeyDown="OnFavoriteFlyoutTreeKeyDown">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="Padding" Value="2,1" />
                    <Setter Property="Margin" Value="0,1,0,1" />
                    <Setter Property="FontSize" Value="12" />
                    <EventSetter Event="Expanded" Handler="OnFavoriteFlyoutTreeItemExpanded" />
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁"
                                   Margin="0,0,6,0"
                                   Foreground="#936A00" />
                        <TextBlock Text="{Binding Name}"
                                   Foreground="#202020" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Border>
    </Grid>
</Window>

<Window x:Class="WorkFileExplorer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:WorkFileExplorer.App.Controls"
        mc:Ignorable="d"
        Title="K탐색기"
        Icon="/Assets/Icons/pro_icon.png"
        Width="1600"
        Height="920"
        MinWidth="1200"
        MinHeight="720"
        Background="#D9D9D9"
        FontFamily="Segoe UI"
        PreviewKeyDown="OnWindowPreviewKeyDown">
    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Height" Value="22" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="#ECECEC" />
            <Setter Property="BorderBrush" Value="#9E9E9E" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="FKeyButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#E4E4E4" />
            <Setter Property="BorderBrush" Value="#8E8E8E" />
        </Style>

        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarSeparatorStyle" TargetType="Border">
            <Setter Property="Width" Value="1" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="#8E8E8E" />
        </Style>

        <Style x:Key="PropertyIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="1,0,1,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Trigger>
                <DataTrigger Binding="{Binding IsParentDirectory}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.35" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SingleRowTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="#D0D0D0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid SnapsToDevicePixels="True" ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}"
                                    BorderThickness="0"
                                    ClipToBounds="True"
                                    Height="24"
                                    VerticalAlignment="Top">
                                <controls:SingleLineTabPanel IsItemsHost="True"
                                                             Margin="2,0,2,0"
                                                             Height="24"
                                                             VerticalAlignment="Top" />
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Visibility="Collapsed"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DetailsVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTileViewEnabled}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TilesVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTileViewEnabled}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="BorderBrush" Value="#7A7A7A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="FontFamily" Value="Malgun Gothic" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="CanUserAddRows" Value="False" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E5E5E5" />
            <Setter Property="Foreground" Value="#202020" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <EventSetter Event="MouseDoubleClick" Handler="OnPanelGridHeaderMouseDoubleClick" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Height" Value="18" />
            <Setter Property="ToolTip" Value="{Binding Memo}" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="100" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A84D6" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <DataTrigger Binding="{Binding HasMemo}" Value="False">
                    <Setter Property="ToolTip" Value="{x:Null}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="1,0,3,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0078D7" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ItemIconStyle" TargetType="Image">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="ItemNameStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8E8" />
        </Style>

        <Style x:Key="TileListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="BorderBrush" Value="#7A7A7A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="124" />
            <Setter Property="Height" Value="124" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Background" Value="#000000" />
            <Setter Property="BorderBrush" Value="#696969" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="ToolTip" Value="{Binding Memo}" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="100" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A84D6" />
                    <Setter Property="BorderBrush" Value="#0A84D6" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <DataTrigger Binding="{Binding HasMemo}" Value="False">
                    <Setter Property="ToolTip" Value="{x:Null}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Background" Value="#000000" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="{Binding Memo}" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="100" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A84D6" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <DataTrigger Binding="{Binding HasMemo}" Value="False">
                    <Setter Property="ToolTip" Value="{x:Null}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="TileItemTemplate">
            <Grid Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="6">
                    <Image x:Name="TileThumbnail"
                           Source="{Binding TileImageSource}"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True" />
                    <Viewbox x:Name="TileIconFallback" StretchDirection="DownOnly" Stretch="Uniform" Margin="10">
                        <Image Style="{StaticResource ItemIconStyle}" Source="{Binding IconPath}" />
                    </Viewbox>
                    <Border x:Name="TilePinBadge"
                            Visibility="Collapsed"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,2,2,0"
                            Background="#202020"
                            CornerRadius="2"
                            Padding="2,0">
                        <TextBlock Text="📌" FontSize="11" Foreground="#FFD54A" />
                    </Border>
                </Grid>
                <Border Grid.Row="1" Background="Transparent" Padding="4,2">
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{Binding HighlightColor}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               HorizontalAlignment="Center" />
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsImageFile}" Value="True">
                    <Setter TargetName="TileIconFallback" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsImageFile}" Value="False">
                    <Setter TargetName="TileThumbnail" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter TargetName="TilePinBadge" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="CompactListItemTemplate">
            <Grid Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Style="{StaticResource ItemIconStyle}" Source="{Binding IconPath}" Margin="2,0,6,0" />
                <TextBlock Grid.Column="1"
                           Text="{Binding DisplayName}"
                           Foreground="{Binding HighlightColor}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <Style x:Key="LeftPathHostStyle" TargetType="Border">
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#9A9A9A" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLeftPanelActive}" Value="True">
                    <Setter Property="Background" Value="#0A84D6" />
                    <Setter Property="BorderBrush" Value="#0A84D6" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RightPathHostStyle" TargetType="Border">
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#9A9A9A" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLeftPanelActive}" Value="False">
                    <Setter Property="Background" Value="#0A84D6" />
                    <Setter Property="BorderBrush" Value="#0A84D6" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PathComboBaseStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#101010" />
            <Setter Property="Padding" Value="2,0,2,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="PathBg"
                                    Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0" />
                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="2,0,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     CaretBrush="{TemplateBinding Foreground}"
                                     VerticalContentAlignment="Center" />
                            <ToggleButton Grid.Column="1"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <TextBlock Text="▼"
                                           FontSize="8"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}" />
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#1F1F1F"
                                        BorderBrush="#6A6A6A"
                                        BorderThickness="1">
                                    <ScrollViewer SnapsToDevicePixels="True" MaxHeight="280">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LeftPathComboInnerStyle" TargetType="ComboBox" BasedOn="{StaticResource PathComboBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLeftPanelActive}" Value="True">
                    <Setter Property="Background" Value="#0A84D6" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RightPathComboInnerStyle" TargetType="ComboBox" BasedOn="{StaticResource PathComboBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLeftPanelActive}" Value="False">
                    <Setter Property="Background" Value="#0A84D6" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FourPanelPathComboInnerStyle" TargetType="ComboBox" BasedOn="{StaticResource PathComboBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#0A84D6" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="FourPanelItemTemplate">
            <Border Margin="2"
                    BorderBrush="#A8A8A8"
                    BorderThickness="1"
                    Background="#D0D0D0"
                    PreviewMouseLeftButtonDown="OnFourPanelSlotPreviewMouseLeftButtonDown"
                    DragOver="OnFourPanelSlotDragOver"
                    Drop="OnFourPanelSlotDrop"
                    AllowDrop="True">
                <Grid x:Name="FourPanelsGridLayoutGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="2,2,2,1">
                        <TextBlock DockPanel.Dock="Right" MinWidth="100" TextAlignment="Right" VerticalAlignment="Center" Text="{Binding FreeSpaceText}" />
                        <ItemsControl ItemsSource="{Binding DataContext.AvailableDrives, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="26"
                                            Height="20"
                                            Margin="0,0,2,0"
                                            Content="{Binding}"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                            Click="OnFourPanelDriveClick" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="2,0,2,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="24" />
                        </Grid.ColumnDefinitions>
                        <TabControl Grid.Column="0"
                                    Style="{StaticResource SingleRowTabControlStyle}"
                                    Margin="0"
                                    Height="24"
                                    ItemsSource="{Binding Tabs}"
                                    SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                                    PreviewMouseRightButtonDown="OnFourPanelTabPreviewMouseRightButtonDown"
                                    MouseDoubleClick="OnFourPanelTabsMouseDoubleClick"
                                    SelectionChanged="OnFourPanelTabSelectionChanged">
                            <TabControl.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="탭 복제" Click="OnFourPanelTabDuplicateClick" />
                                    <MenuItem Header="해당 탭 닫기" Click="OnFourPanelTabCloseCurrentClick" />
                                    <Separator />
                                    <MenuItem Header="왼쪽 탭 닫기" Click="OnFourPanelTabCloseToLeftClick" />
                                    <MenuItem Header="오른쪽 탭 닫기" Click="OnFourPanelTabCloseToRightClick" />
                                    <MenuItem Header="기타 탭 닫기" Click="OnFourPanelTabCloseOthersClick" />
                                </ContextMenu>
                            </TabControl.ContextMenu>
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" Margin="6,0" />
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                            <TabControl.ContentTemplate>
                                <DataTemplate>
                                    <Grid />
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>
                        <Button Grid.Column="1" Width="24" Height="22" Margin="2,1,0,1" Content="+" Click="OnFourPanelAddTabClick" />
                        <Button Grid.Column="2" Width="24" Height="22" Margin="2,1,0,1" Content="-" Click="OnFourPanelCloseTabClick" />
                    </Grid>

                    <DockPanel Grid.Row="2" Margin="2,0,2,1">
                        <Button DockPanel.Dock="Left" Width="24" Height="22" Margin="0,0,2,0" Content="\" ToolTip="홈 폴더" Click="OnFourPanelHomeClick" />
                        <Button DockPanel.Dock="Left" Width="24" Height="22" Margin="0,0,2,0" Content="." ToolTip="상위 폴더" Click="OnFourPanelParentClick" />
                        <Button DockPanel.Dock="Left" Width="24" Height="22" Margin="0,0,2,0" Content="←" ToolTip="뒤로 (이전 경로)" Click="OnFourPanelBackClick" />
                        <Button DockPanel.Dock="Left" Width="24" Height="22" Margin="0,0,2,0" Content="→" ToolTip="앞으로 (다음 경로)" Click="OnFourPanelForwardClick" />
                        <Button DockPanel.Dock="Right" Width="44" Height="22" Margin="2,0,0,0" Content="즐겨찾기" Click="OnFourPanelFavoriteClick" />
                        <Border Margin="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F2F2F2" />
                                    <Setter Property="BorderBrush" Value="#9A9A9A" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Background" Value="#0A84D6" />
                                            <Setter Property="BorderBrush" Value="#0A84D6" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ComboBox Style="{StaticResource FourPanelPathComboInnerStyle}"
                                      IsEditable="True"
                                      Text="{Binding Panel.CurrentPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      ItemsSource="{Binding SelectedTab.HistoryCandidates}"
                                      SelectionChanged="OnFourPanelPathHistorySelectionChanged"
                                      KeyDown="OnFourPanelPathHistoryKeyDown" />
                        </Border>
                    </DockPanel>

                    <Grid Grid.Row="3" Margin="2,0,2,0">
                        <DataGrid Tag="{Binding}"
                                  ItemsSource="{Binding Panel.Items}"
                                  SelectedItem="{Binding Panel.SelectedItem, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  Loaded="OnFourPanelGridLoaded"
                                  PreviewMouseLeftButtonDown="OnFourPanelPreviewMouseLeftButtonDown"
                                  PreviewMouseMove="OnPanelItemsPreviewMouseMove"
                                  DragOver="OnPanelItemsDragOver"
                                  Drop="OnPanelItemsDrop"
                                  AllowDrop="True"
                                  MouseDoubleClick="OnFourPanelDoubleClick"
                                  GotFocus="OnFourPanelFocus"
                                  SelectionChanged="OnFourPanelSelectionChanged">
                            <DataGrid.Style>
                                <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTab.IsTileViewEnabled}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="이름" Width="*" SortMemberPath="Name">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="1,0,0,0">
                                                <TextBlock Text="📌" Margin="0,0,3,0" Visibility="Collapsed" Foreground="#FFD54A">
                                                    <TextBlock.Style>

<Window x:Class="WorkFileExplorer.App.Dialogs.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Viewer"
        Width="1200"
        Height="820"
        MinWidth="700"
        MinHeight="460"
        Background="#1E1E1E"
        Foreground="#F0F0F0"
        WindowStartupLocation="CenterOwner"
        KeyDown="OnWindowKeyDown"
        SizeChanged="OnWindowSizeChanged">
    <Window.Resources>
        <Style x:Key="ViewerToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="12,2" />
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#252A30" />
            <Setter Property="BorderBrush" Value="#4A5159" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2E353D" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#687380" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D2227" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8B98A6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewerToolbarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ViewerToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Style="{StaticResource ViewerToolbarButtonStyle}" Content="Prev" Click="OnPrevClick" />
                <Button Style="{StaticResource ViewerToolbarButtonStyle}" Content="Next" Click="OnNextClick" />
                <Separator Margin="6,0,2,0" />
                <Button Style="{StaticResource ViewerToolbarIconButtonStyle}" Content="-" Click="OnZoomOutClick" />
                <Button Style="{StaticResource ViewerToolbarIconButtonStyle}" Content="+" Click="OnZoomInClick" />
                <Button Style="{StaticResource ViewerToolbarButtonStyle}" MinWidth="46" Margin="6,0,0,0" Content="Fit" Click="OnFitClick" />
                <Button Style="{StaticResource ViewerToolbarButtonStyle}" MinWidth="52" Content="100%" Click="OnActualSizeClick" />
                <Separator Margin="6,0,2,0" />
                <Button Style="{StaticResource ViewerToolbarButtonStyle}" MinWidth="52" Content="RotL" Click="OnRotateLeftClick" />
                <Button Style="{StaticResource ViewerToolbarButtonStyle}" MinWidth="52" Content="RotR" Click="OnRotateRightClick" />
                <Button Style="{StaticResource ViewerToolbarButtonStyle}" MinWidth="52" Content="Flip" Click="OnFlipClick" />
                <Button Style="{StaticResource ViewerToolbarButtonStyle}" MinWidth="58" Content="Full" Click="OnToggleFullScreenClick" />
                <Button Style="{StaticResource ViewerToolbarButtonStyle}" MinWidth="82" Content="Folder" Click="OnOpenFolderClick" />
            </StackPanel>
            <TextBlock x:Name="TopPathText"
                       VerticalAlignment="Center"
                       FontSize="13"
                       TextTrimming="CharacterEllipsis" />
        </DockPanel>


        <Border Grid.Row="1" Background="#0B0B0B" BorderBrush="#404040" BorderThickness="1" MouseLeftButtonDown="OnImageAreaMouseLeftButtonDown">
            <ScrollViewer x:Name="ImageScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="OnImagePreviewMouseWheel">
                <Grid>
                    <Image x:Name="ViewerImage"
                           Stretch="None"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <TextBlock x:Name="ImageInfoText"
                       DockPanel.Dock="Right"
                       VerticalAlignment="Center"
                       Foreground="#CFCFCF" />
        </DockPanel>

        <Border Grid.Row="3" Margin="0,8,0,0" Background="#111111" BorderBrush="#3D3D3D" BorderThickness="1" Padding="4">
            <ListBox x:Name="ThumbnailList"
                     Background="#111111"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="True"
                     SelectionChanged="OnThumbnailSelectionChanged"
                     PreviewMouseWheel="OnThumbnailPreviewMouseWheel">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,6,0" />
                        <Setter Property="Padding" Value="2" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="#4E4E4E" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#204A7A" />
                                <Setter Property="BorderBrush" Value="#4FA5FF" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="98">
                            <Border Width="90" Height="72" Background="#050505" BorderBrush="#2C2C2C" BorderThickness="1" HorizontalAlignment="Center">
                                <Image Source="{Binding Thumbnail}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <TextBlock Margin="2,4,2,0"
                                       Text="{Binding Name}"
                                       Foreground="#CFCFCF"
                                       FontSize="11"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Window>


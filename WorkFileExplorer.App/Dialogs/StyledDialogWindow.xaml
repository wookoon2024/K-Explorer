<Window x:Class="WorkFileExplorer.App.Dialogs.StyledDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="알림"
        Width="420"
        Height="140"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#E9E9E9"
        FontFamily="Malgun Gothic">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <Border Width="28" Height="28" Background="#F2C94C" CornerRadius="4" Margin="0,2,10,0" VerticalAlignment="Top">
                <TextBlock Text="!" FontWeight="Bold" FontSize="18" Foreground="#333333" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock x:Name="MessageTextBlock"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="#1F1F1F" />
        </DockPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SecondaryButton"
                    Width="84"
                    Height="28"
                    Margin="0,0,8,0"
                    Content="취소(N)"
                    IsCancel="True"
                    Click="OnSecondaryClick" />
            <Button x:Name="PrimaryButton"
                    Width="84"
                    Height="28"
                    Content="확인(O)"
                    IsDefault="True"
                    Click="OnPrimaryClick" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="WorkFileExplorer.App.Dialogs.NewFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="새 폴더 만들기"
        Width="460"
        Height="210"
        MinWidth="420"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F4F4"
        FontFamily="Malgun Gothic">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="새 폴더 이름을 입력하세요."
                   FontSize="14"
                   Foreground="#1F1F1F"
                   Margin="0,0,0,8" />

        <Border Grid.Row="1"
                BorderBrush="#B6B6B6"
                BorderThickness="1"
                CornerRadius="4"
                Background="White">
            <TextBox x:Name="FolderNameTextBox"
                     Padding="10,6"
                     BorderThickness="0"
                     FontSize="14"
                     Text="{Binding FolderName, UpdateSourceTrigger=PropertyChanged}" />
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="2,10,2,0"
                   Text="금지 문자(\/:*?&quot;&lt;&gt;|)는 사용할 수 없습니다."
                   Foreground="#666666"
                   FontSize="12" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="96"
                    Height="34"
                    Margin="0,0,8,0"
                    Content="확인"
                    IsDefault="True"
                    Click="OnConfirmClick" />
            <Button Width="96"
                    Height="34"
                    Content="취소"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>

